# --- TaskFlow backend configuration -------------------------------------
# Copy this file to `.env` and adjust as needed. Never commit real secrets.

# HTTP port the API listens on.
PORT=4000

# Secret used to sign JWT auth tokens. MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-change-me-to-a-long-random-string

# Token lifetime in seconds (default 7 days).
JWT_EXPIRES_IN=604800

# SQLite database file (relative to the server/ directory).
DATABASE_FILE=./data/taskflow.db

# Allowed CORS origin for the frontend dev server. Use * to allow any origin.
CORS_ORIGIN=http://localhost:5173

# Demo account created by the seed script (used by the "Demo login" button).
SEED_DEMO_NAME=Алекс Морозов
SEED_DEMO_EMAIL=demo@taskflow.app
SEED_DEMO_PASSWORD=demo1234
