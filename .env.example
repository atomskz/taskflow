# --- Root env for docker compose -----------------------------------------
# Copy to `.env` (read automatically by docker compose). Only used by Docker.

# Secret used by the backend to sign JWTs. CHANGE THIS for any real deployment.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Public domain Caddy serves over HTTPS (needs a DNS A record -> this server).
# Used for TLS termination / Let's Encrypt. Leave unset for local-only runs.
DOMAIN=taskflow.example.com
