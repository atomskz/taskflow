# --- TaskFlow frontend configuration ------------------------------------
# Copy to `.env` (optional for local dev — defaults work out of the box).

# Base origin of the backend API. Leave EMPTY in development: requests go to
# '/api' and Vite proxies them to the backend (see vite.config.js).
# In production, set this to the deployed API origin, e.g. https://api.example.com
VITE_API_URL=

# Where the Vite dev proxy forwards '/api' requests (defaults to localhost:4000).
VITE_PROXY_TARGET=http://localhost:4000
